# Provider: "openai" (default Superdav/OpenAI-compatible), "ollama-native", or "claude-proxy"
TRANSLATE_PROVIDER=openai

# --- Superdav/OpenAI-compatible cloud provider (default) ---
# Use a docs-specific Superdav site token. Do not commit real token values.
OPENAI_API_KEY=<docs-site-token>
OPENAI_API_BASE=https://api.sdaiagent.com/v1
OPENAI_MODEL=superdav-chat-pro

# --- Ollama native local models ---
# TRANSLATE_PROVIDER=ollama-native
# OPENAI_API_BASE=http://127.0.0.1:11434
# OPENAI_MODEL=translategemma:27b

# --- Claude Max Proxy ---
# Requires: https://github.com/rynfar/opencode-claude-max-proxy running locally
# Also requires: claude login (Claude CLI authenticated with Max subscription)
#
# TRANSLATE_PROVIDER=claude-proxy
# OPENAI_API_BASE=http://127.0.0.1:3456
# OPENAI_MODEL=claude-sonnet-4-5-20250929
